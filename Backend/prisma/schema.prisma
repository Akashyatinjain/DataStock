generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  username     String
  email        String       @unique
  password     String?
  storageUsed  Int          @default(0)
  createdAt    DateTime     @default(now())
  authProvider AuthProvider @default(local)
}

model EmailOTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum AuthProvider {
  local
  google
  otp
}
